),\n+486         technical: this.generateTechnicalQuestions(module),\n+487         edgeCase: this.generateEdgeCaseQuestions(module),\n+488         optimization: this.generateOptimizationQuestions(module)\n+489       }\n+490     };\n+491   }\n+492 \n+493   generateBusinessQuestions(module) {\n+494     // 基于模块分析生成 5 道业务流程题\n+495     return [\n+496       {\n+497         id: 1,\n+498         category: 'business',\n+499         question: `用户下单后，${module.name} 内部发生了什么？`,\n+500         hints: [\n+501           '订单状态如何变化？',\n+502           '库存扣减发生在哪个环节？',\n+503           '支付成功/失败分别如何处理？'\n+504         ],\n+505         answer: `1. 订单创建，状态为 PENDING\\n2. 库存预扣减（Redis）\\n3. 调用支付网关\\n4. 支付成功：状态改为 PAID，正式扣减库存\\n5. 支付失败：状态改为 CANCELLED，释放库存`,\n+506         difficulty: 'medium'\n+507       },\n+508       // ... 更多题目\n+509     ];\n+510   }\n+511 \n+512   generateTechnicalQuestions(module) {\n+513     // 基于模块分析生成 8 道技术实现题\n+514     return [\n+515       {\n+516         id: 1,\n+517         category: 'technical',\n+518         question: `${module.name} 用了什么设计模式？为什么？`,\n+519         hints: [\n+520           '观察代码结构',\n+521           '是否有单例、工厂、策略等模式？',\n+522           '相比其他方案有什么优劣？'\n+523         ],\n+524         answer: `使用了策略模式处理不同支付方式。\\n优势：易于扩展新支付方式，符合开闭原则。`,\n+525         difficulty: 'medium'\n+526       },\n+527       // ... 更多题目\n+528     ];\n+529   }\n+530 \n+531   generateEdgeCaseQuestions(module) {\n+532     // 基于模块分析生成 4 道边界场景题\n+533     return [\n+534       {\n+535         id: 1,\n+536         category: 'edgeCase',\n+537         question: `如果数据库连接失败，${module.name} 会怎么处理？`,\n+538         hints: [\n+539           '是否有重试机制？',\n+540           '是否有降级方案？',\n+541           '用户会看到什么错误？'\n+542         ],\n+543         answer: `1. 捕获数据库异常\\n2. 重试 3 次（指数退避）\\n3. 仍失败则返回 503 错误\\n4. 记录错误日志并告警`,\n+544         difficulty: 'hard'\n+545       },\n+546       // ... 更多题目\n+547     ];\n+548   }\n+549 \n+550   generateOptimizationQuestions(module) {\n+551     // 基于模块分析生成 3 道优化思考题\n+552     return [\n+553       {\n+554         id: 1,\n+555         category: 'optimization',\n+556         question: `如果 QPS 提升 10 倍，${module.name} 的瓶颈会在哪里？如何优化？`,\n+557         hints: [\n+558           '数据库查询是否是瓶颈？',\n+559           '是否有缓存可以优化？',\n+560           '是否可以异步处理？'\n+561         ],\n+562         answer: `瓶颈：数据库写入\\n优化方案：\\n1. 引入消息队列异步处理\\n2. 读写分离\\n3. 热点数据缓存到 Redis`,\n+563         difficulty: 'hard'\n+564       },\n+565       // ... 更多题目\n+566     ];\n+567   }\n+568 \n+569   // 生成 Markdown 格式\n+570   toMarkdown(questions) {\n+571     let md = `## 🎯 ${questions.moduleName} 面试题（20 题）\\n\\n`;\n+572     \n+573     const categories = {\n+574       business: '一、业务流程（5 题）',\n+575       technical: '二、技术实现（8 题）',\n+576       edgeCase: '三、边界场景（4 题）',\n+577       optimization: '四、优化思考（3 题）'\n+578     };\n+579 \n+580     for (const [key, title] of Object.entries(categories)) {\n+581       md += `### ${title}\\n\\n`;\n+582       for (const q of questions.categories[key]) {\n+583         md += `#### 题 ${q.id}：${q.question}\\n\\n`;\n+584         md += `**思考提示：**\\n`;\n+585         for (const hint of q.hints) {\n+586           md += `- ${hint}\\n`;\n+587         }\n+588         md += `\\n**参考答案：**\\n${q.answer}\\n\\n---\\n\\n`;\n+589       }\n+590     }\n+591 \n+592     return md;\n+593   }\n+594 }\n+595 \n+596 module.exports = InterviewQuestionsGenerator;\n+597 ```\n+598 \n+599 ---\n+600 \n 434 ### 4. 文档生成器 (lib/docgen.js) - 简化版\n 435 \n 436 ```javascript\n 437 /**\n     ...","firstChangedLine":434},"isError":false,"timestamp":1772501935484}}
