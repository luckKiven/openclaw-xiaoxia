{"type":"message","id":"6513390d","parentId":"b24061c7","timestamp":"2026-03-03T02:35:34.517Z","message":{"role":"toolResult","toolCallId":"call_49849d0dbc3a4587ae9df576","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env node\n\n/**\n * Project X-Ray CLI 入口\n * \n * 项目 X 光透视分析工具\n * 让新手快速理解陌生项目\n * \n * @author jixiang\n * @version 1.0.0\n */\n\nconst { program } = require('commander');\nconst path = require('path');\nconst fs = require('fs-extra');\nconst DependencyManager = require('../lib/dependency-manager');\nconst ProjectScanner = require('../lib/scanner');\nconst ArchitectureAnalyzer = require('../lib/analyzer');\nconst DocumentGenerator = require('../lib/docgen');\n\n// 简单的彩色输出函数\nconst colors = {\n  cyan: (str) => `\\x1b[36m${str}\\x1b[0m`,\n  green: (str) => `\\x1b[32m${str}\\x1b[0m`,\n  red: (str) => `\\x1b[31m${str}\\x1b[0m`,\n  yellow: (str) => `\\x1b[33m${str}\\x1b[0m`,\n  bold: (str) => `\\x1b[1m${str}\\x1b[0m`\n};\n\nprogram\n  .name('xray')\n  .description('🦴 Project X-Ray - 项目 X 光透视分析工具')\n  .version('1.0.0');\n\nprogram\n  .command('analyze <projectPath>')\n  .description('分析项目')\n  .option('-o, --output <dir>', '输出目录', './xray-output')\n  .option('--skip-deps', '跳过依赖检查')\n  .option('--verbose', '详细输出')\n  .action(async (projectPath, options) => {\n    try {\n      console.log(chalk.cyan.bold('\\n🦴 Project X-Ray 开始分析...\\n'));\n\n      // Step 0: 依赖检查\n      if (!options.skipDeps) {\n        const depManager = new DependencyManager();\n        await depManager.ensureDependencies();\n      }\n\n      // Step 1: 扫描项目\n      console.log(chalk.cyan('\\n📂 扫描项目...'));\n      const scanner = new ProjectScanner(projectPath);\n      const scanResult = await scanner.scan();\n      console.log(chalk.green(`✅ 找到 ${scanResult.stats.totalFiles} 个文件`));\n\n      // Step 2: 架构分析\n      console.log(chalk.cyan('\\n🏗️  分析架构...'));\n      const analyzer = new ArchitectureAnalyzer(projectPath, scanResult.techStack);\n      const analysisResult = await analyzer.analyze();\n      console.log(chalk.green(`✅ 找到 ${analysisResult.entryPoints.length} 个入口点`));\n\n      // Step 3: 生成文档\n      console.log(chalk.cyan('\\n📝 生成文档...'));\n      const outputDir = options.output || path.join('F:\\\\2025ideazdjx\\\\openClaw-project\\\\project-desc', `${scanResult.projectName}-xray`);\n      const templateDir = path.join(__dirname, '..', 'templates');\n      const docGen = new DocumentGenerator(templateDir);\n      \n      const fullAnalysis = {\n        ...scanResult,\n        ...analysisResult\n      };\n      \n      await docGen.generateAll(fullAnalysis, outputDir);\n      console.log(chalk.green(`✅ 文档生成完成`));\n\n      // 完成\n      console.log(chalk.cyan.bold('\\n🎉 完成！输出路径：'));\n      console.log(chalk.green(outputDir) + '\\n');\n\n    } catch (error) {\n      console.error(chalk.red('\\n❌ 错误：') + ' ' + error.message);\n      if (options.verbose) {\n        console.error(error);\n      }\n      process.exit(1);\n    }\n  });\n\nprogram.parse();\n"}],"isError":false,"timestamp":1772505334505}}
