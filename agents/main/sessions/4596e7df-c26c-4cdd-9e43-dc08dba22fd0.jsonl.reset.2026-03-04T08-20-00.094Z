{"type":"message","id":"c4830ca2","parentId":"4309e701","timestamp":"2026-03-04T06:57:00.873Z","message":{"role":"toolResult","toolCallId":"call_b014f43dee4f4ea493e3f15d","toolName":"read","content":[{"type":"text","text":"# Qwen Proxy 模型配置\n# 格式：模型名称 → API 端点映射\n\nmodels:\n  # 通义千问 - qwen3.5-plus（主力模型）\n  - name: qwen3.5-plus\n    model_id: qwen-plus\n    api_base: https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions\n    env_key: QWEN_API_KEY\n    timeout: 60\n\n  # 通义千问 - qwen-coder-plus（编程专用）\n  - name: qwen-coder-plus\n    model_id: qwen-coder-plus\n    api_base: https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions\n    env_key: QWEN_API_KEY\n    timeout: 60\n\n  # 通义千问 - qwen3-max（最强模型）\n  - name: qwen3-max\n    model_id: qwen-max\n    api_base: https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions\n    env_key: QWEN_API_KEY\n    timeout: 60\n\n  # Kimi - kimi-k2.5\n  - name: kimi-k2.5\n    model_id: kimi-k2.5\n    api_base: https://api.moonshot.cn/v1/chat/completions\n    env_key: KIMI_API_KEY\n    timeout: 60\n\n  # 智谱 GLM - glm-5\n  - name: glm-5\n    model_id: glm-5\n    api_base: https://open.bigmodel.cn/api/paas/v4/chat/completions\n    env_key: ZHIPU_API_KEY\n    timeout: 60\n"}],"isError":false,"timestamp":1772607420864}}
