{"type":"message","id":"efc162fc","parentId":"5676016a","timestamp":"2026-03-04T06:43:07.118Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在创建核心代理脚本 proxy.py - 支持 Responses API → Chat API 转换\n","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_bc493b6612554cada8174eb8","name":"write","arguments":{"content":"\"\"\"\nQwen Proxy - OpenAI Responses API → Chat Completions 协议转换代理\n支持阿里云通义千问、Kimi、智谱等模型\n\n用法：python proxy.py\n端口：http://localhost:3000\n\"\"\"\n\nfrom fastapi import FastAPI, HTTPException, Header\nfrom fastapi.middleware.cors import CORSMiddleware\nimport httpx\nimport yaml\nimport os\nfrom typing import Optional, Dict, Any\nfrom dotenv import load_dotenv\n\n# 加载环境变量\nload_dotenv()\n\napp = FastAPI(title=\"Qwen Proxy\", version=\"1.0.0\")\n\n# 允许 CORS\napp.add_middleware(\n    CORSMiddleware,\n    allow_origins=[\"*\"],\n    allow_credentials=True,\n    allow_methods=[\"*\"],\n    allow_headers=[\"*\"],\n)\n\n# 加载模型配置\ndef load_models_config() -> Dict[str, Any]:\n    \"\"\"加载 models.yaml 配置\"\"\"\n    config_path = os.path.join(os.path.dirname(__file__), \"models.yaml\")\n    if not os.path.exists(config_path):\n        return {}\n    \n    with open(config_path, \"r\", encoding=\"utf-8\") as f:\n        return yaml.safe_load(f)\n\nMODELS_CONFIG = load_models_config()\n\ndef get_model_info(model_name: str) -> Optional[Dict[str, Any]]:\n    \"\"\"根据模型名称获取配置信息\"\"\"\n    models = MODELS_CONFIG.get(\"models\", [])\n    for model in models:\n        if model.get(\"name\") == model_name:\n            return model\n    return None\n\ndef get_api_key(model_name: str) -> str:\n    \"\"\"获取模型对应的 API Key\"\"\"\n    model_info = get_model_info(model_name)\n    if model_info:\n        env_key = model_info.get(\"env_key\", \"QWEN_API_KEY\")\n    else:\n        env_key = \"QWEN_API_KEY\"\n    \n    api_key = os.getenv(env_key)\n    if not api_key:\n        raise HTTPException(status_code=500, detail=f\"API Key not found: {env_key}\")\n    \n    return api_key\n\n@app.post(\"/v1/responses\")\nasync def responses_proxy(\n    payload: Dict[str, Any],\n    authorization: Optional[str] = Header(None)\n):\n    \"\"\"\n    OpenAI Responses API 端点\n    转换为 Chat Completions API 调用阿里云\n    \"\"\"\n    try:\n        # 1. 解析 Responses API 请求\n        model = payload.get(\"model\", \"qwen3.5-plus\")\n        user_input = payload.get(\"input\")\n        \n        if not user_input:\n            raise HTTPException(status_code=400, detail=\"Missing 'input' field\")\n        \n        # 2. 获取模型配置\n        model_info = get_model_info(model)\n        api_base = model_info.get(\"api_base\") if model_info else None\n        api_key = get_api_key(model)\n        \n        if not api_base:\n            raise HTTPException(status_code=400, detail=f\"Model not configured: {model}\")\n        \n        # 3. 转换为 Chat Completions API 格式\n        chat_payload = {\n            \"model\": model_info.get(\"model_id\", model) if model_info else model,\n            \"messages\": [\n                {\"role\": \"user\", \"content\": user_input}\n            ],\n            \"temperature\": payload.get(\"temperature\", 0.7),\n            \"max_tokens\": payload.get(\"max_tokens\", 2048),\n            \"stream\": False\n        }\n        \n        # 4. 调用阿里云/其他提供商\n        async with httpx.AsyncClient(timeout=60.0) as client:\n            resp = await client.post(\n                api_base,\n                json=chat_payload,\n                headers={\n                    \"Authorization\": f\"Bearer {api_key}\",\n                    \"Content-Type\": \"application/json\"\n                }\n            )\n            \n            if resp.status_code != 200:\n                raise HTTPException(\n                    status_code=resp.status_code,\n                    detail=f\"Upstream error: {resp.text}\"\n                )\n            \n            chat_resp = resp.json()\n        \n        # 5. 转换为 Responses API 格式\n        output = chat_resp.get(\"choices\", [{}])[0].get(\"message\", {}).get(\"content\", \"\")\n        \n        return {\n            \"output\": output,\n            \"status\": \"completed\",\n            \"model\": model,\n            \"usage\": chat_resp.get(\"usage\", {})\n        }\n        \n    except HTTPException:\n        raise\n    except Exception as e:\n        raise HTTPException(status_code=500, detail=str(e))\n\n@app.post(\"/v1/chat/completions\")\nasync def chat_completions_proxy(\n    payload: Dict[str, Any],\n    authorization: Optional[str] = Header(None)\n):\n    \"\"\"\n    Chat Completions API 端点（兼容模式）\n    直接转发到阿里云\n    \"\"\"\n    try:\n        model = payload.get(\"model\", \"qwen3.5-plus\")\n        model_info = get_model_info(model)\n        api_base = model_info.get(\"api_base\") if model_info else None\n        api_key = get_api_key(model)\n        \n        if not api_base:\n            raise HTTPException(status_code=400, detail=f\"Model not configured: {model}\")\n        \n        async with httpx.AsyncClient(timeout=60.0) as client:\n            resp = await client.post(\n                api_base,\n                json=payload,\n                headers={\n                    \"Authorization\": f\"Bearer {api_key}\",\n                    \"Content-Type\": \"application/json\"\n                }\n            )\n            \n            if resp.status_code != 200:\n                raise HTTPException(\n                    status_code=resp.status_code,\n                    detail=f\"Upstream error: {resp.text}\"\n                )\n            \n            return resp.json()\n            \n    except HTTPException:\n        raise\n    except Exception as e:\n        raise HTTPException(status_code=500, detail=str(e))\n\n@app.get(\"/v1/models\")\nasync def list_models():\n    \"\"\"返回可用的模型列表\"\"\"\n    models = MODELS_CONFIG.get(\"models\", [])\n    return {\n        \"object\": \"list\",\n        \"data\": [\n            {\n                \"id\": model.get(\"name\"),\n                \"object\": \"model\",\n                \"created\": 1709625600,\n                \"owned_by\": \"qwen-proxy\"\n            }\n            for model in models\n        ]\n    }\n\n@app.get(\"/health\")\nasync def health_check():\n    \"\"\"健康检查\"\"\"\n    return {\n        \"status\": \"healthy\",\n        \"port\": 3000,\n        \"models_loaded\": len(MODELS_CONFIG.get(\"models\", []))\n    }\n\n@app.get(\"/\")\nasync def root():\n    \"\"\"根路径\"\"\"\n    return {\n        \"service\": \"Qwen Proxy\",\n        \"version\": \"1.0.0\",\n        \"endpoints\": [\n            \"POST /v1/responses\",\n            \"POST /v1/chat/completions\",\n            \"GET /v1/models\",\n            \"GET /health\"\n        ]\n    }\n\nif __name__ == \"__main__\":\n    import uvicorn\n    \n    print(\"\"\"\n╔══════════════════════════════════════════════════════════╗\n║              Qwen Proxy Server v1.0.0                    ║\n║     OpenAI Responses API → Chat Completions Proxy        ║\n╚══════════════════════════════════════════════════════════╝\n\n    启动中...\n    监听地址：http://localhost:3000\n    按 Ctrl+C 停止服务\n    \"\"\")\n    \n    uvicorn.run(app, host=\"0.0.0.0\", port=3000)\n","path":"C:\\qwen-proxy\\proxy.py"}}],"api":"openai-completions","provider":"qwen3-max","model":"qwen3.5-plus","usage":{"input":175360,"output":1836,"cacheRead":0,"cacheWrite":0,"totalTokens":177196,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772606569839}}
