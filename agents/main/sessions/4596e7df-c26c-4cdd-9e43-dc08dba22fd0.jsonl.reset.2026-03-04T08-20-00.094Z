{"type":"message","id":"100afadd","parentId":"8da0e951","timestamp":"2026-03-04T07:05:45.177Z","message":{"role":"toolResult","toolCallId":"call_74307e3180e84c7399f04920","toolName":"read","content":[{"type":"text","text":"    if not api_key:\n        raise HTTPException(status_code=500, detail=f\"API Key not found: {env_key}\")\n    \n    return api_key\n\n@app.post(\"/v1/responses\")\nasync def responses_proxy(\n    payload: Dict[str, Any],\n    authorization: Optional[str] = Header(None)\n):\n    \"\"\"\n    OpenAI Responses API 端点\n    转换为 Chat Completions API 调用阿里云\n    \"\"\"\n    try:\n        # 1. 解析 Responses API 请求\n        model = payload.get(\"model\", \"qwen3.5-plus\")\n        user_input = payload.get(\"input\")\n        \n        if not user_input:\n            raise HTTPException(status_code=400, detail=\"Missing 'input' field\")\n        \n        # 2. 获取模型配置\n        model_info = get_model_info(model)\n        api_base = model_info.get(\"api_base\") if model_info else None\n        api_key = get_api_key(model)\n        \n        if not api_base:\n            raise HTTPException(status_code=400, detail=f\"Model not configured: {model}\")\n        \n        # 3. 转换为 Chat Completions API 格式\n        chat_payload = {\n            \"model\": model_info.get(\"model_id\", model) if model_info else model,\n            \"messages\": [\n                {\"role\": \"user\", \"content\": user_input}\n            ],\n            \"temperature\": payload.get(\"temperature\", 0.7),\n            \"max_tokens\": payload.get(\"max_tokens\", 2048),\n            \"stream\": False\n        }\n        \n        # 4. 调用阿里云/其他提供商\n        async with httpx.AsyncClient(timeout=60.0) as client:\n            resp = await client.post(\n                api_base,\n                json=chat_payload,\n                headers={\n                    \"Authorization\": f\"Bearer {api_key}\",\n                    \"Content-Type\": \"application/json\"\n                }\n\n[122 more lines in file. Use offset=110 to continue.]"}],"isError":false,"timestamp":1772607945167}}
